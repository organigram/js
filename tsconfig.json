{
    "extends": "@tsconfig/recommended/tsconfig.json",
    "compilerOptions": {
      "noImplicitAny": true,
      "removeComments": true,
      "resolveJsonModule": true,
      "preserveConstEnums": true,
      "outDir": "dist",
      "sourceMap": false,
      "declaration": true,
      "declarationDir": "./types"
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "**/*.spec.ts"]
}