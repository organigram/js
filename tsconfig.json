{
  "extends": "@tsconfig/recommended/tsconfig.json",
  "compilerOptions": {
    "lib": ["ESNext"],
    "target": "ESNext",
    "skipLibCheck": true,
    "noImplicitAny": true,
    "removeComments": true,
    "resolveJsonModule": true,
    "preserveConstEnums": true,
    "outDir": "dist",
    "sourceMap": false,
    "declaration": true,
    "declarationDir": "./types"
  },
  "include": ["src/**/*.ts", "./namespaces.d.ts", "scripts/**/*.js"],
  "exclude": ["node_modules", "types", "dist"]
}
