{
    "extends": "@tsconfig/recommended/tsconfig.json",
    "compilerOptions": {
      "noImplicitAny": true,
      "removeComments": true,
      "resolveJsonModule": true,
      "preserveConstEnums": true,
      "outDir": "dist",
      "sourceMap": false
    },
    "include": ["src/**/*", "src/index.d.ts"],
    "exclude": ["node_modules", "**/*.spec.ts"]
}