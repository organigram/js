{
  "extends": "@tsconfig/recommended/tsconfig.json",
  "compilerOptions": {
    "lib": ["ESNext", "DOM"],
    "target": "ESNext",
    "strict": true,
    "removeComments": false,
    "resolveJsonModule": true,
    "preserveConstEnums": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "rootDir": "src",
    "outDir": "dist",
    "sourceMap": false,
    "declaration": true
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": [
    "node_modules",
    "types",
    "dist",
    "jest.config.ts",
    "tests",
    "scripts"
  ]
}
